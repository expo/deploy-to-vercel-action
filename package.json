{
  "name": "deploy-to-vercel-action",
  "version": "2.0.0",
  "description": "Deploy your project to Vercel using GitHub Actions. Supports PR previews and GitHub deployments.",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint ./src",
    "dev": "node src/index.js",
    "start": "node dist/index.js",
    "build": "esbuild src/index.js --bundle --platform=node --target=node24 --format=cjs --conditions=import --outfile=dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/expo/deploy-to-vercel-action.git"
  },
  "keywords": [],
  "author": "Maximilian Schiller <schiller@mxis.ch>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/expo/deploy-to-vercel-action/issues"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.0.0",
    "action-input-parser": "^1.2.38",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
